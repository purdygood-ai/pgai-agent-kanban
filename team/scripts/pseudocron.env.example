# pseudocron.env.example — Example environment file for pseudocron.py
#
# install-pseudocron.sh installs this file automatically when pseudocron.env
# does not already exist.  To install both pseudocron.cfg and pseudocron.env
# in one step, run:
#
#   team/scripts/install-pseudocron.sh --wake-tier=small   # (default)
#   team/scripts/install-pseudocron.sh --wake-tier=medium
#   team/scripts/install-pseudocron.sh --wake-tier=large
#
# To copy and edit this file manually:
#
#   cp team/scripts/pseudocron.env.example "$PGAI_AGENT_KANBAN_ROOT_PATH/pseudocron.env"
#   $EDITOR "$PGAI_AGENT_KANBAN_ROOT_PATH/pseudocron.env"
#
# Note: an existing pseudocron.env is NEVER overwritten by install-pseudocron.sh
# (it may contain operator customizations).  Delete the file and re-run
# install-pseudocron.sh to regenerate from this example.
#
# -----------------------------------------------------------------------
# PURPOSE
# -----------------------------------------------------------------------
#
# Pseudocron reads this file at startup and merges the variables it finds
# into the environment passed to every child process.  This lets your
# scheduled commands see environment variables without requiring you to
# hardcode them in each command line.
#
# If this file does not exist, pseudocron starts with its own bare
# environment and logs a notice to stderr.  That is not an error.
#
# -----------------------------------------------------------------------
# FORMAT
# -----------------------------------------------------------------------
#
#   export NAME=VALUE       — standard bash export form (preferred)
#   NAME=VALUE              — bare assignment (also accepted)
#   # comment               — ignored
#   <blank line>            — ignored
#
# Supported value styles:
#   export FOO=plain_value
#   export FOO="value with spaces"
#   export FOO='value with spaces'
#
# NOT supported (no shell expansion):
#   export FOO=$(command)   — command substitution
#   export FOO=${BAR:-default}  — parameter expansion
#   If you need these, pre-expand them in a real shell and paste the
#   literal values here.
#
# -----------------------------------------------------------------------
# EXAMPLES — uncomment and adjust as needed
# -----------------------------------------------------------------------

# --- Kanban root (required for wake scripts) ---
# export PGAI_AGENT_KANBAN_ROOT_PATH=/home/rocky/pgai_agent_kanban

# --- PATH — ensure child processes find the right binaries ---
# export PATH=/usr/local/bin:/usr/bin:/bin:/home/rocky/.local/bin

# --- HOME — set if pseudocron is run by a system init (no home dir) ---
# export HOME=/home/rocky

# --- Claude API key (if wake scripts need it) ---
# export ANTHROPIC_API_KEY=<your-key-here>

# --- Project-specific variables ---
# export MY_VAR=some_value
# export DB_HOST=localhost
# export DB_PORT=5432

# -----------------------------------------------------------------------
# Add your variables below this line.
# -----------------------------------------------------------------------
