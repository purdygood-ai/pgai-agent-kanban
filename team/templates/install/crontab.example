# pgai-agent-kanban: crontab.example
#
# This file documents the every-2-minutes sub-minute stagger scheduling pattern.
#
# IMPORTANT: Replace __KANBAN_ROOT__ with the absolute path to your kanban
# root before installing.  install-crontab.sh performs this substitution
# automatically using the installed kanban root path.
#
# To install/update your crontab using this pattern:
#   team/scripts/install-crontab.sh
#
# To install manually:
#   KANBAN=$(grep PGAI_AGENT_KANBAN_ROOT_PATH ~/pgai_agent_kanban/kanban.cfg | cut -d= -f2-)
#   crontab -l > ~/.crontab.backup && crontab - < <(crontab -l; ...)

# --- Environment ---
PGAI_AGENT_KANBAN_ROOT_PATH=__KANBAN_ROOT__
PATH=__CLAUDE_PATH__:/usr/local/bin:/usr/bin:/bin

# =============================================================================
# SCHEDULING PATTERN — every-2-minutes with sub-minute stagger
# =============================================================================
# Maximum wait between agent firings: ~60 seconds (within the 2-minute cycle)
# Best-case agent-to-agent handoff: 21 seconds (same minute, adjacent slot)
#
# How the stagger works:
#   - Even minutes (*/2):     PM fires at :00, CM at :00+21s, TESTER at :00+42s
#   - Odd minutes (1-59/2):   CODER fires at :01, WRITER at :01+21s
#
# The --sleep=N parameter delays the script N seconds after cron fires but
# BEFORE acquiring the work-queue lock.  Concurrent slots don't block each other.
#
# Operator tuning:
#   - Swap CODER/WRITER to even minutes and PM/CM/TESTER to odd if preferred.
#   - Adjust sleep offsets (0, 21, 42) for different stagger rhythms.
#   - Use 0-59 for N in --sleep=N; values >= 60 trigger a warning.

# --- Even-minute agents (release-side: pm, cm, tester) ---
# PM fires every 2 minutes, starting at minute 0: :00, :02, :04, ...
*/2 * * * * __KANBAN_ROOT__/scripts/wake-batch.sh --agent=pm     --sleep=0  >> __KANBAN_ROOT__/logs/cron-pm.log 2>&1

# CM fires every 2 minutes with 21-second sub-minute delay: :00+21s, :02+21s, ...
*/2 * * * * __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=21 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1

# TESTER fires every 2 minutes with 42-second sub-minute delay: :00+42s, :02+42s, ...
*/2 * * * * __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=42 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1

# --- Odd-minute agents (work-producers: coder, writer) ---
# CODER fires every 2 minutes, starting at minute 1: :01, :03, :05, ...
1-59/2 * * * * __KANBAN_ROOT__/scripts/wake-batch.sh --agent=coder  --sleep=0  >> __KANBAN_ROOT__/logs/cron-coder.log 2>&1

# WRITER fires every 2 minutes, starting at minute 1, with 21-second delay: :01+21s, :03+21s, ...
1-59/2 * * * * __KANBAN_ROOT__/scripts/wake-batch.sh --agent=writer --sleep=21 >> __KANBAN_ROOT__/logs/cron-writer.log 2>&1

# --- Cleanup Script (weekly, Sundays at 4:00 AM) ---
0 4 * * 0 __KANBAN_ROOT__/scripts/cleanup/cleanup.sh >> __KANBAN_ROOT__/logs/cron-cleanup.log 2>&1

# --- Trivial-log purge (daily at 04:15, opt-in) ---
# Uncomment to enable daily purge of small stale batch logs:
# 15 4 * * * __KANBAN_ROOT__/scripts/cleanup/cleanup.sh --trivial-only >> __KANBAN_ROOT__/logs/cron-cleanup-trivial.log 2>&1

# --- OVERWATCH Tier-1 sweep (hourly at :30) ---
# Fires once per hour at minute 30.  Operator-tunable: adjust the minute (30)
# to any preferred slot; change the second field from * to */2 for every-2-hours.
30 * * * * __KANBAN_ROOT__/scripts/overwatch-sweep.sh >> __KANBAN_ROOT__/logs/cron-overwatch-sweep.log 2>&1

# --- OVERWATCH Tier-2 deep-clean (daily at 03:30) ---
# LLM-driven review of the action log and any sweep-flagged anomalies.
# The daily cadence keeps model cost bounded; the 03:30 slot avoids the
# hourly sweep at :30 by an hour and sits during a low-traffic window.
30 3 * * * __KANBAN_ROOT__/scripts/wake-batch.sh --agent=overwatch --sleep=0 --max-tasks=1 >> __KANBAN_ROOT__/logs/cron-overwatch.log 2>&1

# --- Log Cleanup (daily at 04:30) ---
30 4 * * * __KANBAN_ROOT__/scripts/cleanup/cleanup_logs.sh >> __KANBAN_ROOT__/logs/cron-cleanup-logs.log 2>&1
