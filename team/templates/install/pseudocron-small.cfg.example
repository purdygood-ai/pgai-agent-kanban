26 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1
31 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1
36 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1
41 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1
46 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1
51 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1
56 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=cm     --sleep=0 >> __KANBAN_ROOT__/logs/cron-cm.log 2>&1

# --- TESTER: fires every 5 minutes starting at minute 2 (2-minute offset) ---
2  __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=0 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1
7  __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=0 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1
12 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=0 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1
17 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=0 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1
22 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=0 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1
