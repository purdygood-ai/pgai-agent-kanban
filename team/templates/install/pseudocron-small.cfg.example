57 __KANBAN_ROOT__/scripts/wake-batch.sh --agent=tester --sleep=0 >> __KANBAN_ROOT__/logs/cron-tester.log 2>&1

# --- CODER: fires every 5 minutes starting at minute 3 (3-minute offset) ---
3  __KANBAN_ROOT__/scripts/wake-batch.sh --agent=coder  --sleep=0 >> __KANBAN_ROOT__/logs/cron-coder.log 2>&1
