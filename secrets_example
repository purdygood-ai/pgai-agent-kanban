# secrets_example — sensitive credentials sourced before each wake firing.
#
# Copy to "secrets" in the kanban root and edit:
#
#   cp secrets_example "$PGAI_AGENT_KANBAN_ROOT_PATH/secrets"
#   chmod 600 "$PGAI_AGENT_KANBAN_ROOT_PATH/secrets"
#
# The "secrets" file is shell-sourced by wake_common.sh. Put OAuth tokens,
# API keys, and any other sensitive credentials here. Anything that should
# NOT be committed to git or logged in plaintext belongs in this file.
#
# Security notes:
#   - The live "secrets" file is gitignored. Never commit it.
#   - The file is shell-sourced — any syntax error halts the wake firing.
#     Test edits with: bash -n $PGAI_AGENT_KANBAN_ROOT_PATH/secrets
#   - Mode should be 0600 (operator-readable only). The install hint above
#     sets this; preserve it if you back up or copy the file.
#   - This file is OPTIONAL — wake scripts work without it as long as
#     credentials are available through some other mechanism (e.g. the
#     credentials file written by `claude login`).
#
# Authentication mode (AI_AUTH_MODE):
#   wake_common.sh reads ai_auth_mode from kanban.cfg [providers] and exports
#   AI_AUTH_MODE before sourcing this file. The if/else block below branches on
#   that value so you only need to configure credentials for the mode you use.
#
#   oauth  (default): Claude Code OAuth flow. Unsets API-key variables so they
#          cannot accidentally override the OAuth token in downstream tools.
#          No entries in this file are required — `claude login` credentials
#          are used automatically by the Claude CLI.
#
#   apikey: Traditional API key flow. Uncomment the ANTHROPIC_API_KEY export
#          and set your key. OAuth variables are left as-is.
#
# All lines below are commented out by default. Uncomment to use.


# --- Auth-mode credential block ---
# This block branches on AI_AUTH_MODE (set by wake_common.sh from kanban.cfg).
if [[ "${AI_AUTH_MODE:-oauth}" == "apikey" ]]; then
    # apikey mode: export your Anthropic API key here.
    # NEVER commit a real key — replace the placeholder with your actual key
    # in your live secrets file (which is gitignored).
    # export ANTHROPIC_API_KEY="sk-ant-YOUR-KEY-HERE"
    # export OPENAI_API_KEY="sk-ant-YOUR-KEY-HERE"
    :
else
    # oauth mode (default): unset API-key variables so they cannot
    # accidentally override OAuth credentials in downstream tools.
    unset ANTHROPIC_API_KEY
    unset OPENAI_API_KEY # codex doesnt work this way; but good to unset anyway
    # export CLAUDE_CODE_OAUTH_TOKEN="sk-ant-..."
    # CODEX uses their auth json file so you dont need a OAUTH token here
fi


